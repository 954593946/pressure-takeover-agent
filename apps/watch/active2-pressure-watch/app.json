{
  "configVersion": "v3",
  "app": {
    "appId": 20301,
    "appName": "AURI Watch",
    "appType": "app",
    "version": {
      "code": 2,
      "name": "0.2.0"
    },
    "icon": "icon.png",
    "vender": "pressure-agent",
    "description": "AURI wrist status and health bridge for Amazfit Active 2"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "data:user.hd.heart_rate",
    "data:user.hd.spo2",
    "data:user.hd.sleep"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "4.2",
      "target": "4.2",
      "minVersion": "4.2"
    }
  },
  "debug": false,
  "targets": {
    "active2": {
      "module": {
        "page": {
          "pages": [
            "page/active2/home/index.page"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "name": "Amazfit Active 2 (Round)",
          "deviceSource": 8913152,
          "st": "r",
          "sr": "w466"
        },
        {
          "name": "Amazfit Active 2 (Round)",
          "deviceSource": 8913153,
          "st": "r",
          "sr": "w466"
        },
        {
          "name": "Amazfit Active 2 NFC (Round)",
          "deviceSource": 10092800,
          "st": "r",
          "sr": "w466"
        },
        {
          "name": "Amazfit Active 2 NFC (Round)",
          "deviceSource": 10092801,
          "st": "r",
          "sr": "w466"
        }
      ],
      "designWidth": 466
    }
  },
  "i18n": {
    "en-US": {
      "appName": "AURI Watch"
    },
    "zh-CN": {
      "appName": "AURI 手表"
    }
  },
  "defaultLanguage": "zh-CN"
}
