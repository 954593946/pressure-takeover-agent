{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pressure-agent.local/contracts/event.schema.json",
  "title": "Pressure Agent Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "type",
    "source",
    "occurredAt",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "task.input.received",
        "meeting.delay.reported",
        "vehicle.mode.changed",
        "traffic.updated",
        "pressure.signal.reported",
        "assistance.requested",
        "confirmation.submitted",
        "wearable.status.reported",
        "demo.reset.requested"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "mobile",
        "vehicle_hmi",
        "wearable",
        "demo_console",
        "agent_api"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationId": {
      "type": "string"
    },
    "deviceId": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
