{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auri.local/contracts/event.schema.json",
  "title": "AURI Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "session_id", "type", "source", "timestamp", "payload"],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "event_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "type": {
      "type": "string",
      "enum": [
        "task.created",
        "meeting.overrun",
        "scene.approaching",
        "scene.vehicle_entered",
        "scene.parked",
        "traffic.updated",
        "wearable.signal",
        "driving.signal",
        "user.utterance",
        "service.mock.config",
        "confirmation.confirmed",
        "cooldown.elapsed",
        "session.reset"
      ]
    },
    "source": {
      "type": "string",
      "enum": ["mobile", "vehicle_hmi", "wearable", "demo_console", "agent_api"]
    },
    "timestamp": {"type": "string", "format": "date-time"},
    "correlation_id": {"type": ["string", "null"]},
    "device_id": {"type": ["string", "null"]},
    "payload": {"type": "object", "additionalProperties": true}
  }
}
