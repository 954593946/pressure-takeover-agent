{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auri.local/contracts/world-state.schema.json",
  "title": "AURI World State",
  "$ref": "#/$defs/WorldState",
  "$defs": {
    "Task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "title", "task_type", "priority", "adjustable", "status", "capability_tags"],
      "properties": {
        "task_id": {"type": "string"},
        "title": {"type": "string"},
        "scheduled_at": {"type": ["string", "null"], "format": "date-time"},
        "location": {"type": ["string", "null"]},
        "task_type": {"enum": ["rigid", "flexible"]},
        "priority": {"enum": ["low", "medium", "high"]},
        "adjustable": {"type": "boolean"},
        "status": {"enum": ["pending", "rescheduled", "completed"]},
        "waiting_party": {"type": "array", "items": {"type": "string"}},
        "capability_tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "Event": {
      "$ref": "event.schema.json"
    },
    "Action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "type", "target", "status", "risk", "requires_confirmation", "summary"],
      "properties": {
        "action_id": {"type": "string"},
        "type": {"enum": ["message", "reschedule", "service_order"]},
        "target": {"type": "string"},
        "status": {"enum": ["planned", "ready", "awaiting_confirmation", "completed", "blocked", "failed"]},
        "risk": {"enum": ["low", "medium", "high"]},
        "requires_confirmation": {"type": "boolean"},
        "summary": {"type": "string"},
        "details_ref": {"type": ["string", "null"]},
        "error_code": {"type": ["string", "null"]}
      }
    },
    "Confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmation_id", "action_ids", "expires_at", "status", "owner_surface"],
      "properties": {
        "confirmation_id": {"type": "string"},
        "action_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "expires_at": {"type": "string", "format": "date-time"},
        "status": {"enum": ["pending", "accepted", "rejected", "expired"]},
        "confirmed_by": {"type": ["string", "null"]},
        "owner_surface": {"enum": ["mobile", "vehicle_hmi"]}
      }
    },
    "Profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "profile_type", "tone", "proactive_voice_threshold", "haptic_mode", "budget_limit", "delivery_priority", "substitution_policy", "explanation_depth"],
      "properties": {
        "profile_id": {"type": "string"},
        "profile_type": {"enum": ["efficiency", "quality"]},
        "tone": {"type": "string"},
        "proactive_voice_threshold": {"enum": ["L1", "L2", "L3"]},
        "haptic_mode": {"enum": ["clear", "gentle"]},
        "budget_limit": {"type": "number", "minimum": 0},
        "delivery_priority": {"enum": ["fastest", "quality_first"]},
        "substitution_policy": {"enum": ["same_spec_within_budget", "same_brand_only"]},
        "explanation_depth": {"enum": ["brief", "detailed"]}
      }
    },
    "WearableState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connected", "mode", "text", "color", "haptic", "command_id"],
      "properties": {
        "connected": {"type": "boolean"},
        "mode": {"enum": ["idle", "warning", "handover", "processing", "completed", "error"]},
        "text": {"type": "string"},
        "color": {"enum": ["navy", "blue", "yellow", "green", "red"]},
        "haptic": {"enum": ["none", "double_short", "single_pulse", "three_beat", "soft_short", "error_once"]},
        "command_id": {"type": "string"},
        "heart_rate": {"type": ["integer", "null"], "minimum": 20, "maximum": 250},
        "signal_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      }
    },
    "ServiceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sku", "name", "quantity", "unit_price", "subtotal"],
      "properties": {
        "sku": {"type": "string"},
        "name": {"type": "string"},
        "quantity": {"type": "integer", "minimum": 1},
        "unit_price": {"type": "number", "minimum": 0},
        "subtotal": {"type": "number", "minimum": 0},
        "substitution": {"type": ["string", "null"]}
      }
    },
    "ServiceOrder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order_id", "preview_id", "items", "total", "budget_limit", "budget_status", "delivery_window", "status"],
      "properties": {
        "order_id": {"type": ["string", "null"]},
        "preview_id": {"type": "string"},
        "items": {"type": "array", "items": {"$ref": "#/$defs/ServiceItem"}},
        "total": {"type": "number", "minimum": 0},
        "budget_limit": {"type": "number", "minimum": 0},
        "budget_status": {"enum": ["within_budget", "over_budget"]},
        "delivery_window": {"type": "string"},
        "status": {"enum": ["preview", "awaiting_confirmation", "submitted", "blocked", "failed"]},
        "error_code": {"type": ["string", "null"], "enum": [null, "OUT_OF_STOCK", "OVER_BUDGET", "DUPLICATE", "EXPIRED", "NOT_AUTHORIZED", "NOT_FOUND"]}
      }
    },
    "Risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pressure_level", "late_minutes", "reason_codes", "auxiliary_signals"],
      "properties": {
        "pressure_level": {"enum": ["L0", "L1", "L2", "L3", "Recovery"]},
        "late_minutes": {"type": "integer", "minimum": 0},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "auxiliary_signals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "InteractionOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message_id", "priority", "owner_surface", "suppressed_surfaces", "expires_at", "requires_confirmation", "conclusion"],
      "properties": {
        "message_id": {"type": "string"},
        "priority": {"enum": ["low", "normal", "high", "critical"]},
        "owner_surface": {"enum": ["mobile", "vehicle_hmi", "none"]},
        "suppressed_surfaces": {"type": "array", "items": {"enum": ["mobile", "vehicle_hmi", "wearable"]}},
        "expires_at": {"type": "string", "format": "date-time"},
        "requires_confirmation": {"type": "boolean"},
        "conclusion": {"type": "string"}
      }
    },
    "WorldState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "session_id", "revision", "updated_at", "stage", "scene", "primary_surface", "risk", "tasks", "actions", "profile", "wearable", "service_orders", "action_ledger"],
      "properties": {
        "schema_version": {"const": "0.2.0"},
        "session_id": {"type": "string"},
        "revision": {"type": "integer", "minimum": 0},
        "updated_at": {"type": "string", "format": "date-time"},
        "stage": {"enum": ["off_vehicle_idle", "pre_departure_warning", "handover_to_vehicle", "vehicle_observation", "takeover_L2", "takeover_L3", "planning", "service_prepared", "waiting_confirmation", "executing", "service_executed", "action_completed", "cooldown", "parked_review", "error"]},
        "scene": {"enum": ["off_vehicle", "approaching_vehicle", "driving", "high_load_driving", "parked"]},
        "primary_surface": {"enum": ["mobile", "vehicle_hmi", "none"]},
        "risk": {"$ref": "#/$defs/Risk"},
        "tasks": {"type": "array", "items": {"$ref": "#/$defs/Task"}},
        "eta": {"type": ["string", "null"], "format": "date-time"},
        "actions": {"type": "array", "items": {"$ref": "#/$defs/Action"}},
        "confirmation": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/Confirmation"}]},
        "profile": {"$ref": "#/$defs/Profile"},
        "wearable": {"$ref": "#/$defs/WearableState"},
        "service_orders": {"type": "array", "items": {"$ref": "#/$defs/ServiceOrder"}},
        "output": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/InteractionOutput"}]},
        "action_ledger": {"type": "array", "items": {"type": "string"}},
        "service_mock_mode": {"enum": ["success", "out_of_stock", "over_budget"]}
      }
    }
  }
}
