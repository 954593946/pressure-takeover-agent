# Bosch/OpenAI-compatible LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://example.com/llmservice/api/v1
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=30
LLM_ENABLED=true

# Optional shared-backend access control. Leave empty for localhost-only work.
# When binding to 0.0.0.0, set a random value and send it as X-Agent-Token.
AGENT_SHARED_TOKEN=

# Optional speech providers (not required by agent-api)
ASR_API_KEY=
TTS_API_KEY=

# Runtime
HOST=127.0.0.1
PORT=8000
AGENT_API_BASE_URL=http://127.0.0.1:8000
AGENT_STREAM_URL=http://127.0.0.1:8000/v1/stream
# Use * only for a temporary shared Demo backend without cookies/credentials.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
DEMO_MODE=true

# Never put real contact details in the repository.
DEMO_TEACHER_NAME=王老师
DEMO_FAMILY_NAME=家人
